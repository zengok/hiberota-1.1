DJANGO_SETTINGS_MODULE=config.settings.staging
DJANGO_SECRET_KEY=replace-with-staging-secret-from-secret-manager
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=staging.hiberota.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.hiberota.com
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
SECURITY_CSP_UPGRADE_INSECURE_REQUESTS=true
STAGING_ROBOTS_NOINDEX=true
ADMIN_TOTP_REQUIRED=true
ADMIN_LOGIN_RATE_LIMIT_ATTEMPTS=5
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=900
LOG_LEVEL=INFO
MONITOR_SITE_URL=https://staging.hiberota.com
MONITOR_DISK_PATH=/
MONITOR_DISK_MAX_PERCENT=80
MONITOR_BACKUP_MAX_AGE_HOURS=26
ALERT_WEBHOOK_URL=

POSTGRES_DB=hiberota_staging
POSTGRES_USER=hiberota_staging
POSTGRES_PASSWORD=replace-with-staging-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_CONN_MAX_AGE=60

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
SOURCE_SCHEDULER_ENABLED=false

SECURITY_CONTACT_EMAIL=security@hiberota.com
ADMIN_CONTACT_EMAIL=admin@hiberota.com
SUPPORT_CONTACT_EMAIL=support@hiberota.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=replace-with-staging-smtp-host
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-staging-smtp-user
EMAIL_HOST_PASSWORD=replace-with-staging-smtp-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@hiberota.com
SITE_BASE_URL=https://staging.hiberota.com
SECURITY_TXT_CONTACT=mailto:security@hiberota.com
GA4_MEASUREMENT_ID=
CMP_ENABLED=false
CMP_PROVIDER_NAME=
CMP_SCRIPT_URL=
ADSENSE_ENABLED=false
ADSENSE_PUBLISHER_ID=
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_CALL_LIST_TOP=
ADSENSE_SLOT_CALL_DETAIL_INLINE=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
